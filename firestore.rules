rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Art of the Day — public read, admin write
    match /artOfTheDay/{date} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Polls — public read, admin write
    match /polls/{date} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Journal prompts — public read/write (app stores daily prompt for dedup)
    match /journalPrompts/{date} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Shared YouTube channels — public read, authenticated write
    match /channels/{channelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User data — users can only read/write their own
    match /users/{userId}/journalEntries/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/youtubeChannels/{channelId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
