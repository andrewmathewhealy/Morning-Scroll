# Copy this to .env.local for local development
# In production, set this in your hosting platform (Vercel, Netlify, etc.)

# Point at your local Wrangler dev server during development:
VITE_WORKER_URL=http://localhost:8787

# Point at your deployed Worker in production:
# VITE_WORKER_URL=https://morning-scroll-api.<your-subdomain>.workers.dev
